# Runtime mode
# - local: no Jira/Confluence credentials, everything stored under project/
# - atlassian: Jira/Confluence are canonical stores, but prompt packets and run history stay local
AJP_MODE=local

# Shared Atlassian Cloud auth for Jira Cloud and Confluence Cloud
# Use the Atlassian account email that owns the API token.
ATLASSIAN_EMAIL=
# Create this at https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=

# Jira Cloud site root only. Example: https://example.atlassian.net
JIRA_BASE_URL=
# Jira project key where app tasks will be created. Example: AJP
JIRA_PROJECT_KEY=

# Confluence Cloud site root including /wiki. Example: https://example.atlassian.net/wiki
CONFLUENCE_BASE_URL=
# Confluence space key that holds project context and artifact pages. Example: AJP
CONFLUENCE_SPACE_KEY=
# Existing numeric parent page ID for the canonical 03_Context page. Example: 100
CONFLUENCE_CONTEXT_PARENT_ID=
# Existing numeric parent page ID for generated artifact pages. Example: 200
CONFLUENCE_ARTIFACTS_PARENT_ID=
